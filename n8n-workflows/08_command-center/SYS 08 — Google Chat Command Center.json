    {
      "parameters": {
        "jsCode": "const result = $('Parse Command').first().json;\nconst text =\n  (result.data && typeof result.data.text === 'string' && result.data.text) ||\n  (typeof result.text === 'string' && result.text) ||\n  '';\nlet parsed;\ntry {\n  parsed = text ? JSON.parse(text) : { command: 'unknown', params: {} };\n} catch (e) {\n  parsed = { command: 'unknown', params: {} };\n}\nif (!parsed || typeof parsed !== 'object') {\n  parsed = { command: 'unknown', params: {} };\n}\nif (!parsed.command) parsed.command = 'unknown';\n\nreturn [{ json: parsed }];"
      },
