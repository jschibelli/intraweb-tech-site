    {
      "parameters": {
        "jsCode": "const rows = $('Query Revenue').all();\nconst now = new Date();\nconst currentMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;\n\nconst monthRow = rows.find(r => (r.json.Month || '').startsWith(currentMonth));\nlet text;\nif (monthRow) {\n  text = `Revenue (${currentMonth}):\\nInvoiced: $${monthRow.json.Invoiced || 0}\\nCollected: $${monthRow.json.Collected || 0}\\nOutstanding: $${monthRow.json.Outstanding || 0}\\nOverdue: $${monthRow.json.Overdue || 0}`;\n} else {\n  text = `No revenue data found for ${currentMonth}`;\n}\n\nreturn [{ json: { text } }];"
      },
