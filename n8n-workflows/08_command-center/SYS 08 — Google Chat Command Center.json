    {
      "parameters": {
        "jsCode": "const raw = $('Chat Webhook').first().json;\nlet input = raw;\nif (raw && raw.body != null) {\n  if (typeof raw.body === 'object' && !Array.isArray(raw.body)) {\n    input = raw.body;\n  } else if (typeof raw.body === 'string') {\n    try {\n      const parsed = JSON.parse(raw.body);\n      if (parsed && typeof parsed === 'object') input = parsed;\n    } catch (e) {}\n  }\n}\n\nfunction extractUserMessage(obj) {\n  if (!obj || typeof obj !== 'object') return '';\n  const evt = obj.event && typeof obj.event === 'object' ? obj.event : obj;\n  const msg = evt.message || obj.message;\n  if (msg && typeof msg === 'object') {\n    const t = msg.text || msg.argumentText || msg.formattedText;\n    if (typeof t === 'string' && t.trim()) {\n      return t\n        .replace(/<users\\/[^>]+>/g, ' ')\n        .replace(/\\s+/g, ' ')\n        .trim();\n    }\n  }\n  if (typeof obj.text === 'string' && obj.text.trim()) return obj.text.trim();\n  return '';\n}\n\nconst message = extractUserMessage(input);\n\nreturn [{\n  json: {\n    systemPrompt: 'Parse this Google Chat message into a structured command. Return JSON only: { \"command\": \"string\", \"params\": {} }. Valid commands: leads_this_week, pipeline_status, overdue_invoices, client_health, approve_post, send_followup, due_this_week, revenue_this_month, regenerate_manual, unknown. Extract any relevant params like row numbers or contact names.',\n    userPrompt: message,\n    maxTokens: 500\n  }\n}];"
      },
