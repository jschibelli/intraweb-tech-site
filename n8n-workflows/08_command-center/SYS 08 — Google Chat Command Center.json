    {
      "parameters": {
        "jsCode": "const leads = $('Query Leads').all();\nconst count = leads.length;\nconst top3 = leads.slice(0, 3).map(l => {\n  const p = l.json.properties || l.json;\n  return `${p.firstname || ''} ${p.lastname || ''} (${p.company || 'N/A'}) — Score: ${p.lead_score || 0}`;\n}).join('\\n');\n\nreturn [{ json: { text: `Leads this week: ${count}\\n\\nTop 3:\\n${top3 || 'None'}` } }];"
      },
      "id": "sys12-leads-format",
      "name": "Format Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1790,
        50
      ]
    },
