      "id": "sys12-pipeline",
      "name": "Query Pipeline",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [
        1570,
        200
      ],
      "credentials": {
        "hubspotApi": {
          "id": "volH6pGD5psvPC7a",
          "name": "HubSpot App Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const deals = $('Query Pipeline').all();\nconst stages = {};\nfor (const d of deals) {\n  const p = d.json.properties || d.json;\n  const s = p.dealstage || 'unknown';\n  if (!stages[s]) stages[s] = { count: 0, value: 0 };\n  stages[s].count++;\n  stages[s].value += parseFloat(p.amount) || 0;\n}\n\nlet text = 'Pipeline Status:\\n';\nfor (const [stage, data] of Object.entries(stages)) {\n  text += `${stage}: ${data.count} deals ($${data.value})\\n`;\n}\n\nreturn [{ json: { text } }];"
      },
      "id": "sys12-pipeline-format",
      "name": "Format Pipeline",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1790,
        200
      ]
    },
