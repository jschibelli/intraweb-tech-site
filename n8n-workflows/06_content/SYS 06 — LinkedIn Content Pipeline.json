    {
      "parameters": {
        "jsCode": "const feeds = [\n  $('Fetch TechCrunch AI').first().json,\n  $('Fetch VentureBeat AI').first().json,\n  $('Fetch HN Top').first().json\n];\n\nconst allStories = [];\nconst now = new Date();\nconst oneDayAgo = new Date(now - 24 * 60 * 60 * 1000);\n\nfor (const feed of feeds) {\n  const text = typeof feed === 'string' ? feed : (feed.data || feed.body || JSON.stringify(feed));\n  const items = text.match(/<item[\\s\\S]*?<\\/item>/gi) || [];\n\n  for (const item of items) {\n    const titleMatch = item.match(/<title[^>]*>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?<\\/title>/i);\n    const descMatch = item.match(/<description[^>]*>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?<\\/description>/i);\n    const linkMatch = item.match(/<link[^>]*>(.*?)<\\/link>/i);\n    const dateMatch = item.match(/<pubDate[^>]*>(.*?)<\\/pubDate>/i);\n\n    if (titleMatch) {\n      const pubDate = dateMatch ? new Date(dateMatch[1]) : now;\n      if (pubDate >= oneDayAgo) {\n        allStories.push({\n          title: titleMatch[1].replace(/<[^>]*>/g, '').trim(),\n          summary: descMatch ? descMatch[1].replace(/<[^>]*>/g, '').trim().substring(0, 300) : '',\n          link: linkMatch ? linkMatch[1].trim() : '',\n          date: pubDate.toISOString()\n        });\n      }\n    }\n  }\n}\n\nconst top5 = allStories.slice(0, 5);\n\nreturn top5.map(story => ({ json: story }));"
      },
      "id": "sys07-parse",
      "name": "Parse & Filter Stories",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const story = $input.first().json;\n\nreturn [{\n  json: {\n    systemPrompt: `Write LinkedIn posts for John, founder of IntraWeb Technologies. Voice: builder not talker, engineering-first, contrarian with specifics. No buzzwords, no corporate speak, no em dashes. No 'I\\'ve been thinking', no context-setting openers. Structure: Problem > Insight > Framework > Takeaway. 700-900 characters. 3-5 hashtags at bottom only. Forced-choice CTA. 0-1 emojis. Never use: game-changer, revolutionize, leverage, excited to share, delve, in today\\'s world. Return JSON only: { \"hook\": \"\", \"full_post\": \"\", \"hashtags\": \"\", \"suggested_link\": \"\", \"news_source\": \"\" }`,\n    userPrompt: `Headline: ${story.title}\\nSummary: ${story.summary}\\nSource: ${story.link}\\n\\nWrite a contrarian take, not a summary.`,\n    maxTokens: 1500\n  }\n}];"
      },
