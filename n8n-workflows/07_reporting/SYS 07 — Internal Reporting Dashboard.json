      {
        "parameters": {
          "jsCode": "const deals = $('Fetch All Deals').all();\n// Get Config is not a direct input; use item linking from the first deal row\nconst config = $('Get Config (Schedule)').itemMatching(0).json;\nconst now = new Date();\n\nlet openDeals = 0, openValue = 0, closedWonCount = 0, closedWonValue = 0;\nlet activeClients = 0, totalMRR = 0, totalHealthScore = 0, healthCount = 0;\n\nfor (const d of deals) {\n  const p = d.json.properties || d.json;\n  const stage = p.dealstage || '';\n  const amount = parseFloat(p.amount) || 0;\n\n  if (['closed_won', 'invoice_sent', 'paid', 'project_complete'].includes(stage)) {\n    activeClients++;\n    totalMRR += parseFloat(p.monthly_retainer) || 0;\n    const hs = parseFloat(p.client_health_score) || 0;\n    if (hs > 0) { totalHealthScore += hs; healthCount++; }\n  }\n\n  if (!['paid', 'lost', 'project_complete'].includes(stage)) {\n    openDeals++;\n    openValue += amount;\n  }\n\n  if (stage === 'closed_won' || stage === 'paid') {\n    closedWonCount++;\n    closedWonValue += amount;\n  }\n}\n\nconst avgHealth = healthCount > 0 ? Math.round(totalHealthScore / healthCount * 10) / 10 : 0;\n\n// Metric names must match Summary tab headers from create-master-sheet.gs exactly for update to find rows\nconst metrics = [\n  { metric: 'Total Active Leads', value: '' },\n  { metric: 'Hot Leads (score >= 7)', value: '' },\n  { metric: 'Warm Leads (score 4-6)', value: '' },\n  { metric: 'Open Deals Count', value: openDeals },\n  { metric: 'Open Deals Value', value: openValue },\n  { metric: 'Closed Won This Month (count)', value: closedWonCount },\n  { metric: 'Closed Won This Month (value)', value: closedWonValue },\n  { metric: 'Active Clients', value: activeClients },\n  { metric: 'Total MRR', value: totalMRR },\n  { metric: 'Average Health Score', value: avgHealth },\n  { metric: 'Overdue Invoices Count', value: '' },\n  { metric: 'Overdue Invoices Value', value: '' },\n  { metric: 'LinkedIn Posts This Month', value: '' },\n  { metric: 'Automations Executed Today', value: '' },\n  { metric: 'Automations Executed This Week', value: '' }\n];\n\nreturn metrics.map(m => ({\n  json: {\n    sheetId: config.google?.masterSheetId,\n    Metric: m.metric,\n    Value: m.value,\n    'Last Updated': now.toISOString()\n  }\n}));"
        },
