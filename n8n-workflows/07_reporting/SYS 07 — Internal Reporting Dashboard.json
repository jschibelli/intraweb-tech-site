        "parameters": {
          "jsCode": "// Merged item: webhook payload + CONFIG (n8n only resolves $('...') on nodes that connect to this Code node)\nconst j = $input.first().json;\nconst hub = j.body && typeof j.body === 'object' && (j.body.properties !== undefined || j.body.id !== undefined) ? j.body : j;\nconst props = hub.properties || hub;\nconst sheetId = j.google?.masterSheetId;\nif (!sheetId) throw new Error('Missing google.masterSheetId (merge webhook branch with Get Config output)');\n\nreturn [{\n  json: {\n    sheetId,\n    dealName: props.dealname || '',\n    stage: props.dealstage || '',\n    value: props.amount || 0,\n    closeDate: props.closedate || '',\n    daysInStage: 0,\n    owner: props.hubspot_owner_id || 'John'\n  }\n}];"
