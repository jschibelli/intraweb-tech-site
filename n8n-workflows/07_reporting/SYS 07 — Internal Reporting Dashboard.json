    {
      "parameters": {
        "jsCode": "// Merged item: webhook payload + CONFIG (n8n only resolves $('...') on nodes that connect to this Code node)\nconst j = $input.first().json;\nconst hub = j.body && typeof j.body === 'object' && (j.body.properties !== undefined || j.body.id !== undefined) ? j.body : j;\nconst props = hub.properties || hub;\nconst sheetId = j.google?.masterSheetId;\nif (!sheetId) throw new Error('Missing google.masterSheetId (merge webhook branch with Get Config output)');\n\nreturn [{\n  json: {\n    sheetId,\n    dealName: props.dealname || '',\n    stage: props.dealstage || '',\n    value: props.amount || 0,\n    closeDate: props.closedate || '',\n    daysInStage: 0,\n    owner: props.hubspot_owner_id || 'John'\n  }\n}];"
      },
      "id": "sys09-deal-format",
      "name": "Format Deal Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        200
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "mode": "id",
          "value": "={{ $json.sheetId }}"
        },
        "sheetName": {
          "mode": "name",
          "value": "Pipeline"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Deal Name": "={{ $json.dealName }}",
            "Stage": "={{ $json.stage }}",
            "Value": "={{ $json.value }}",
            "Close Date": "={{ $json.closeDate }}",
            "Days in Stage": "={{ $json.daysInStage }}",
            "Owner": "={{ $json.owner }}"
          }
        },
        "options": {}
      },
      "id": "sys09-deal-append",
      "name": "Append to Pipeline",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        910,
        200
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "IJzDJS1jpbItegZD",
          "name": "Google Sheets account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst hub = j.body && typeof j.body === 'object' && (j.body.properties !== undefined || j.body.id !== undefined) ? j.body : j;\nconst props = hub.properties || hub;\nconst sheetId = j.google?.masterSheetId;\nif (!sheetId) throw new Error('Missing google.masterSheetId (merge webhook branch with Get Config output)');\n\nreturn [{\n  json: {\n    sheetId,\n    timestamp: new Date().toISOString(),\n    name: `${props.firstname || ''} ${props.lastname || ''}`.trim(),\n    company: props.company || '',\n    industry: props.industry || '',\n    source: props.lead_source || '',\n    leadScore: props.lead_score || 0,\n    status: props.hs_lead_status || props.lead_status || ''\n  }\n}];"
      },
      "id": "sys09-contact-format",
      "name": "Format Contact Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        500
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "mode": "id",
          "value": "={{ $json.sheetId }}"
        },
        "sheetName": {
          "mode": "name",
          "value": "Leads"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Timestamp": "={{ $json.timestamp }}",
            "Name": "={{ $json.name }}",
            "Company": "={{ $json.company }}",
            "Industry": "={{ $json.industry }}",
            "Source": "={{ $json.source }}",
            "Lead Score": "={{ $json.leadScore }}",
            "Status": "={{ $json.status }}"
          }
        },
        "options": {}
      },
      "id": "sys09-contact-append",
      "name": "Append to Leads",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        910,
        500
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "IJzDJS1jpbItegZD",
          "name": "Google Sheets account 2"
        }
      }
    },
    {
      "parameters": {
        "resource": "deal",
        "operation": "getAll",
        "limit": 200,
        "options": {
          "properties": [
            "dealname",
            "dealstage",
            "amount",
            "closedate",
            "tier",
            "monthly_retainer",
            "client_health_score"
          ]
        }
      },
      "id": "sys09-fetch-deals",
      "name": "Fetch All Deals",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [
        690,
        800
      ],
      "credentials": {
        "hubspotApi": {
          "id": "volH6pGD5psvPC7a",
          "name": "HubSpot App Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const deals = $('Fetch All Deals').all();\n// Get Config is not a direct input; use item linking from the first deal row\nconst config = $('Get Config (Schedule)').itemMatching(0).json;\nconst now = new Date();\n\nlet openDeals = 0, openValue = 0, closedWonCount = 0, closedWonValue = 0;\nlet activeClients = 0, totalMRR = 0, totalHealthScore = 0, healthCount = 0;\n\nfor (const d of deals) {\n  const p = d.json.properties || d.json;\n  const stage = p.dealstage || '';\n  const amount = parseFloat(p.amount) || 0;\n\n  if (['closed_won', 'invoice_sent', 'paid', 'project_complete'].includes(stage)) {\n    activeClients++;\n    totalMRR += parseFloat(p.monthly_retainer) || 0;\n    const hs = parseFloat(p.client_health_score) || 0;\n    if (hs > 0) { totalHealthScore += hs; healthCount++; }\n  }\n\n  if (!['paid', 'lost', 'project_complete'].includes(stage)) {\n    openDeals++;\n    openValue += amount;\n  }\n\n  if (stage === 'closed_won' || stage === 'paid') {\n    closedWonCount++;\n    closedWonValue += amount;\n  }\n}\n\nconst avgHealth = healthCount > 0 ? Math.round(totalHealthScore / healthCount * 10) / 10 : 0;\n\n// Metric names must match Summary tab headers from create-master-sheet.gs exactly for update to find rows\nconst metrics = [\n  { metric: 'Total Active Leads', value: '' },\n  { metric: 'Hot Leads (score >= 7)', value: '' },\n  { metric: 'Warm Leads (score 4-6)', value: '' },\n  { metric: 'Open Deals Count', value: openDeals },\n  { metric: 'Open Deals Value', value: openValue },\n  { metric: 'Closed Won This Month (count)', value: closedWonCount },\n  { metric: 'Closed Won This Month (value)', value: closedWonValue },\n  { metric: 'Active Clients', value: activeClients },\n  { metric: 'Total MRR', value: totalMRR },\n  { metric: 'Average Health Score', value: avgHealth },\n  { metric: 'Overdue Invoices Count', value: '' },\n  { metric: 'Overdue Invoices Value', value: '' },\n  { metric: 'LinkedIn Posts This Month', value: '' },\n  { metric: 'Automations Executed Today', value: '' },\n  { metric: 'Automations Executed This Week', value: '' }\n];\n\nreturn metrics.map(m => ({\n  json: {\n    sheetId: config.google?.masterSheetId,\n    Metric: m.metric,\n    Value: m.value,\n    'Last Updated': now.toISOString()\n  }\n}));"
      },
      "id": "sys09-calc-summary",
      "name": "Calculate Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        910,
