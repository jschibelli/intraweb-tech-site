          "jsCode": "const j = $input.first().json;\nconst hub = j.body && typeof j.body === 'object' && (j.body.properties !== undefined || j.body.id !== undefined) ? j.body : j;\nconst props = hub.properties || hub;\nconst sheetId = j.google?.masterSheetId;\nif (!sheetId) throw new Error('Missing google.masterSheetId (merge webhook branch with Get Config output)');\n\nreturn [{\n  json: {\n    sheetId,\n    timestamp: new Date().toISOString(),\n    name: `${props.firstname || ''} ${props.lastname || ''}`.trim(),\n    company: props.company || '',\n    industry: props.industry || '',\n    source: props.lead_source || '',\n    leadScore: props.lead_score || 0,\n    status: props.hs_lead_status || props.lead_status || ''\n  }\n}];"
