          "value": "Summary"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Metric": "={{ $json.Metric }}",
            "Value": "={{ $json.Value }}",
            "Last Updated": "={{ $json['Last Updated'] }}"
          },
          "matchingColumns": [
            "Metric"
          ]
        },
        "options": {}
      },
      "id": "sys09-update-summary",
      "name": "Update Summary Tab",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        1130,
        800
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "IJzDJS1jpbItegZD",
          "name": "Google Sheets account 2"
        }
      }
    }
