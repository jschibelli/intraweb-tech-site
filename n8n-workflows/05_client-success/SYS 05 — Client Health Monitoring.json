    {
      "parameters": {
        "jsCode": "// Each item = HubSpot deal merged with CONFIG (n8n 2.x / task runner only resolves $('...') from nodes that connect to this Code node)\nconst CONFIG_KEYS = ['owner', 'pipeline', 'hunter', 'google', 'branding', 'timing', 'scoring', 'leadSourcing', 'tiers', 'industries', 'leadSourcingQueries'];\nfunction pickConfig(j) {\n  const o = {};\n  for (const k of CONFIG_KEYS) {\n    if (j[k] !== undefined) o[k] = j[k];\n  }\n  return o;\n}\nconst now = new Date();\nreturn $input.all().map(({ json: j }) => {\n  const config = pickConfig(j);\n  if (!config.scoring) throw new Error('Missing CONFIG on merged items — check Merge Deals + Config (inputs 0=deals, 1=Get Config)');\n  const p = j.properties || j;\n  let score = 0;\n  const lastContact = p.last_activity_date ? new Date(p.last_activity_date) : null;\n  const daysSinceContact = lastContact ? (now - lastContact) / (24 * 60 * 60 * 1000) : 999;\n  if (daysSinceContact < 7) score += 3;\n  else if (daysSinceContact <= 14) score += 1;\n  else score -= 2;\n  const invoiceOverdue = p.dealstage === 'invoice_sent';\n  if (invoiceOverdue) score -= 3;\n  return {\n    json: {\n      dealId: j.id,\n      clientName: p.dealname || '',\n      tier: p.tier || '',\n      contactEmail: p.contact_email || '',\n      contactFirstName: p.contact_firstname || '',\n      healthScore: score,\n      daysSinceContact: Math.round(daysSinceContact),\n      lastContactDate: lastContact ? lastContact.toISOString().split('T')[0] : 'Never',\n      isWarning: score < config.scoring.healthScoreWarningThreshold,\n      config\n    }\n  };\n});"
      },
      "id": "sys10-calc",
      "name": "Calculate Health Scores",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        288
      ]
    },
