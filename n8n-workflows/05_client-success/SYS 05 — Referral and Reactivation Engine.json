    {
      "parameters": {
        "jsCode": "const deal = $('Deal Project Complete').first().json;\nconst config = $('Get Config (Referral)').first().json;\nconst props = deal.properties || deal;\n\nreturn [{\n  json: {\n    clientName: props.dealname || '',\n    contactEmail: props.contact_email || '',\n    contactFirstName: props.contact_firstname || '',\n    contactPhone: props.contact_phone || '',\n    industry: props.industry || '',\n    tier: props.tier || '',\n    dealId: deal.id || deal.dealId || '',\n    config\n  }\n}];"
      },
      "id": "sys11-ref-extract",
      "name": "Extract Referral Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        208
      ]
    },
    {
      "parameters": {
        "amount": "={{ $json.config.timing.referralDelayDays }}",
        "unit": "days"
      },
      "id": "sys11-ref-wait",
      "name": "Wait Referral Delay",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        912,
        208
      ],
      "webhookId": "f60d8b2e-1c71-4f30-98ea-f6bfb0aaa251"
    },
    {
      "parameters": {
        "jsCode": "const d = $('Extract Referral Data').first().json;\n\nreturn [{\n  json: {\n    to: d.contactEmail,\n    subject: `Quick ask, ${d.contactFirstName}`,\n    html: `<p>Hi ${d.contactFirstName},</p><p>Now that we've wrapped up your project, I wanted to ask — do you know anyone else in the ${d.industry || 'business'} space who might benefit from the kind of automation we built for ${d.clientName}?</p><p>A warm intro goes a long way. If someone comes to mind, just reply with their name and I'll take it from there. No pressure at all.</p><p>Thanks for trusting us with your operations. It's been a great project.</p><p>— John<br/>${d.config.owner.companyName}</p>`,\n    workflowName: 'SYS 05 — Referral & Reactivation Engine'\n  }\n}];"
      },
      "id": "sys11-ref-email-prep",
      "name": "Prep Referral Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        208
      ]
    },
    {
      "parameters": {
        "source": "parameter",
        "options": {}
      },
