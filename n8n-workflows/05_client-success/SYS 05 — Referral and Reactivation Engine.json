      {
        "parameters": {
          "jsCode": "const contacts = $('Get Inactive Customers').all();\nconst config = $('Get Config (Reactivation)').first().json;\nconst now = new Date();\nconst threshold = config.timing.reactivationDays * 24 * 60 * 60 * 1000;\n\nconst inactive = contacts.filter(c => {\n  const p = c.json.properties || c.json;\n  const lastActivity = p.last_activity_date ? new Date(p.last_activity_date) : null;\n  return !lastActivity || (now - lastActivity) > threshold;\n});\n\nreturn inactive.map(c => {\n  const p = c.json.properties || c.json;\n  return {\n    json: {\n      contactId: c.json.id,\n      firstName: p.firstname || '',\n      lastName: p.lastname || '',\n      email: p.email || '',\n      phone: p.phone || '',\n      company: p.company || '',\n      config\n    }\n  };\n});"
        },
        "id": "sys11-react-filter",
        "name": "Filter Inactive",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
