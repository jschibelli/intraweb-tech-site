    {
      "parameters": {
        "jsCode": "const deals = $('Get Active Clients').all();\nconst config = $('Get Config').first().json;\nconst now = new Date();\nconst sevenDaysAgo = new Date(now - 7 * 24 * 60 * 60 * 1000);\n\nreturn deals.map(deal => {\n  const props = deal.json.properties || deal.json;\n  const lastActivity = props.last_activity_date ? new Date(props.last_activity_date) : null;\n  const noActivity = !lastActivity || lastActivity < sevenDaysAgo;\n\n  return {\n    json: {\n      dealId: deal.json.id,\n      clientName: props.dealname || '',\n      tier: props.tier || 'starter',\n      contactEmail: props.contact_email || '',\n      contactFirstName: props.contact_firstname || '',\n      dealStage: props.dealstage || '',\n      noRecentActivity: noActivity,\n      config\n    }\n  };\n});"
      },
      "id": "sys08-process",
      "name": "Process Each Client",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "no-activity",
              "leftValue": "={{ $json.noRecentActivity }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "sys08-check-activity",
      "name": "No Recent Activity?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1136,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\nreturn [{\n  json: {\n    message: `No activity logged for ${d.clientName} in 7 days — add notes before update sends`,\n    priority: 'warning'\n  }\n}];"
      },
