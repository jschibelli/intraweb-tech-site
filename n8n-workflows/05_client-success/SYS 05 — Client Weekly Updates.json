    {
      "parameters": {
        "jsCode": "const claude = $('Generate Update').first().json;\nconst d = $('Process Each Client').first().json;\n\nreturn [{\n  json: {\n    to: d.contactEmail,\n    subject: `Weekly Update — ${d.clientName}`,\n    html: claude.data.text,\n    workflowName: 'SYS 05 — Client Weekly Updates'\n  }\n}];"
      },
