    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\nreturn [{\n  json: {\n    systemPrompt: 'Write a weekly client update email for IntraWeb Technologies. Tone: direct, professional, no filler. Sections: What we did this week, What\\'s next, Items needed from you. Return HTML only. No markdown, no backticks.',\n    userPrompt: `Client: ${d.clientName}\\nTier: ${d.tier}\\nDeal stage: ${d.dealStage}\\nRecent activity: ${d.noRecentActivity ? 'No logged activity this week' : 'Activity logged this week'}\\n\\nWrite a professional weekly update email.`,\n    maxTokens: 2000\n  }\n}];"
      },
