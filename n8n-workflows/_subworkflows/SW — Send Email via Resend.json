          "id": "5a3lBUTq9SU0ADbQ",
          "name": "Resend API"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const prep = $('Prepare Email').first().json;\n\nreturn [{\n  json: {\n    workflowName: prep.workflowName,\n    contactName: '',\n    phone: '',\n    eventType: 'email_sent',\n    status: 'success',\n    notes: `Email sent to ${prep.to}`\n  }\n}];"
      },
      "id": "1afa681f-864e-4549-9bd4-e62aef44f4d5",
      "name": "Prepare Log Entry",
