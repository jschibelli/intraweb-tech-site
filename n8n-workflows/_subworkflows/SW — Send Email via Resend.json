        "jsCode": "const response = $('Send via Resend').first().json;\n\nreturn [{\n  json: {\n    success: true,\n    data: { sent: true, emailId: response.id || null, to: $('Prepare Email').first().json.to },\n    error: null\n  }\n}];"
      },
      "id": "839042ad-fe8a-4a6b-a15d-4eb59d03c2c1",
